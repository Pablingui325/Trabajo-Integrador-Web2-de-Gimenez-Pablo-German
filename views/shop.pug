extends ./layout.pug 

block metadata 
  title Fotaza - Tienda Comercial 

block content 
  h1 Tienda de la comunidad 
  p Explora y adquiri licencias digitales de fotografias exclusivas creadas por nuestros usuarios.

  if shopPhotos.lenght > 0
    .row 
      each photo in shopPhotos 
        .col-md-4.mb-4 
          .card.h-100 
            a(href=`/photo/${photo.id}`) 
              img.card-img-top(src=photo.url, alt=photo.title, style="height: 250px; object-fit: cover;")
            .card-body.d-flex.flex-column
              h5.card-title #{photo.title}
              p.card-text.text-muted.small Por @#{photo.author.username}

              .mt-auto.d-flex.justify-content-between.align-items-center
                span.h5.text-success.mb-0 $#{photo.price}
                form(action="/cart/add" method="POST" style="display: inline;")
                  input(type="hidden" name="_csrf" value=csrfToken)
                  input(type="hidden" name="photoId" value=photo.id)
                  button.btn.btn-outline-success.btn-sm(type="submit") Añadir al carrito
  else
    .text-center.my-5
      <h3>No hay fotos a la venta actualmente</h3>
      <p class="text-muted">Volvé a ingresar más tarde para descubrir nuevo contenido comercial.</p>