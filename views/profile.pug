extends ./layout.pug

block metadata
  title Fotaza - Perfil de #{user.username}

block content
  // Cabecera del Perfil
  header.profile-header
    img(src=user.avatarUrl || '/images/default-avatar.png', alt=user.username, style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover;")
    h1 #{user.firstName} #{user.lastName} (@#{user.username})
    p #{user.bio || 'Sin biografía aún.'}
    
    // Estadísticas
    p
      strong #{photos.length} 

      | Publicaciones | 
      strong #{user.followersCount || 0} 

      | Seguidores | 
      strong #{user.followingCount || 0} 
      | Siguiendo
    
    if isCurrentUser
      a.btn.btn-primary(href='/profile/edit') Editar Perfil
    else
      button.btn.btn-success Seguir

  hr
  
  // Galería de fotos creadas por el usuario
  h2 Fotografías compartidas
  if photos.length > 0
    .row
      each photo in photos
        .col-md-4.mb-3
          .card
            a(href=`/photo/${photo.id}`)
              img.card-img-top(src=photo.url, alt=photo.title, style="height: 250px; object-fit: cover;")
            if photo.isForSale
              .card-body
                span.badge.bg-success Venta: $#{photo.price}
  else
    p.text-muted Este usuario todavía no ha compartido ninguna fotografía.

