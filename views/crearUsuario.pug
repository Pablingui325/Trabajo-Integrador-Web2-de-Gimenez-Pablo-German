extends ./layout.pug 

block metadata 
  title Fotaza - Crear Usuario

block content 
  .container.my-4(style="max-width: 600px;")
    h1.text-center Únete a la Comunidad
    p.text-muted.text-center Ingrese los datos solicitados para crear su usuario en Fotaza.
    
    form(action="/signup" method="POST" class="shadow-sm p-4 border rounded bg-white")
      input(type="hidden" name="_csrf" value=csrfToken)
      
      .mb-3
        label.form-label.fw-bold(for="email") Correo Electrónico:
        input#email.form-control(type="email" name="email" placeholder="ejemplo@correo.com" required)
      
      .row
        .col-md-6.mb-3
          label.form-label.fw-bold(for="firstName") Nombre:
          input#firstName.form-control(type="text" name="firstName" required)
        .col-md-6.mb-3
          label.form-label.fw-bold(for="lastName") Apellido:
          input#lastName.form-control(type="text" name="lastName" required)
      
      .mb-3
        label.form-label.fw-bold(for="userName") Nombre de Usuario (ID único):
        .input-group
          span.input-group-text @
          input#userName.form-control(type="text" name="userName" required)
        small.text-muted Este apodo te identificará en tus publicaciones y comentarios.
      
      .row
        .col-md-6.mb-3
          label.form-label.fw-bold(for="birthDay") Fecha de nacimiento: 
          input#birthDay.form-control(type="date" name="birthDay" required)
        .col-md-6.mb-3
          label.form-label.fw-bold(for="gender") Género: 
          select#gender.form-select(name="gender" required)
            option(value="Masculino") Masculino
            option(value="Femenino") Femenino
            option(value="Otro") Otro

      .mb-3 
        label.form-label.fw-bold(for="phone") Número de teléfono: 
        input#phone.form-control(type="tel" name="phone" placeholder="Ej: +5491122334455" required)
      
      .row
        .col-md-6.mb-3
          label.form-label.fw-bold(for="password") Contraseña:
          input#password.form-control(type="password" name="password" required)
        .col-md-6.mb-3
          label.form-label.fw-bold(for="confirmPassword") Confirmar contraseña: 
          input#confirmPassword.form-control(type="password" name="confirmPassword" required)
      
      .form-check.my-3
        input#terms.form-check-input(type="checkbox" name="terms" required)
        label.form-check-label.small.text-muted(for="terms") 
          | Acepto las 
          a(href="/terms" target="_blank") Normas de Comportamiento y Condiciones de Uso
          |  de Fotaza de forma obligatoria.
      
      button.btn.btn-success.w-100.btn-lg.mt-2(type="submit") Registrarse e Ingresar
      
    .text-center.mt-4
      p.text-muted ¿Ya tenés una cuenta? 
        a.fw-bold(href="/login") Iniciar Sesión
    