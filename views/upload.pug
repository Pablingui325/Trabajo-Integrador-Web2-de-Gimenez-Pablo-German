extends ./layout.pug 

block metadata 
  title Fotaza - Compartir Foto 

block content 
  h1 Compartir una foto en la comunidad.
  p Recuerda que tus publicaciones deben cumplir con las normas de comportamiento y condiciones de uso de Fotaza 

  form(action="/upload" method="POST" enctype="multipart/form-data")
    input(type="hidden" name="_csrf" value=csrfToken)

    .form-group.mb-3 
      label(for="photoFile") Seleccione el archivo de imagen: 
      input#photoFile.form-control(type="file" name="photoFile" accept="image/*" required)
    
    .form-group.mb-3 
      label(for="title") Titulo de la Foto: 
      input#title.form-control(type="text" name="title" placeholder="Ej: Atardecer en la montaña" required)

    .form-group.mb-3 
      label(for="description") Descripcion (opcional):
      textarea#description.form-control(name="description" rows="3" placeholder="Contale a la comunidad la historia detrás de esta foto...")

    .form-group.mb-3 
      label(for="tags") Etiquetas / Tags (Separadas por comas):
      input#tags.form-control(type="text" name="tags" placeholder="Ej: naturaleza, paisaje, verano")

    fieldset.border.p-3.rounded.mb-3
      legend.w-auto.px-2 Opciones de Venta

      .form-check.mb-2 
        input#isForSale.form-check-input(type="checkbox" name="isForSale" value="true")
        label.form-check-label(for="isForSale") Poner esta foto a la venta

      .form-group 
        label(for="price") Precio de venta (USD)
        input#price.form-control(type="number" name="price" min="0" step="0.01" placeholder="Ej: 9.99")
        small.text-muted Si se vende, los usuarios podrán descargar la versión en alta resolución.
    
    br
    button.btn.btn-success(type="submit") Publicar Foto 
    br

h2 ¿No queres publicar nada?
  a(href="/") Volver al inicio
        